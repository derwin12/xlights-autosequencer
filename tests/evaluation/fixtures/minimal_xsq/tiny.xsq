        <Effect startTime="0" endTime="1000" name="Marquee" label="" ref="0" palette="0"/>
      </EffectLayer>
      <EffectLayer>
        <Effect startTime="2000" endTime="3000" name="Plasma" label="" ref="1" palette="1"/>
